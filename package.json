{
  "name": "plausible-mcp",
  "version": "0.1.0",
  "description": "MCP server for Plausible Analytics — query your website stats from AI assistants like Claude",
  "type": "module",
  "bin": {
    "plausible-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "plausible",
    "plausible-analytics",
    "analytics",
    "ai",
    "claude"
  ],
  "author": "Defilan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Defilan/plausible-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Defilan/plausible-mcp/issues"
  },
  "homepage": "https://github.com/Defilan/plausible-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
